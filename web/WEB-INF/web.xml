<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <servlet>
        <servlet-name>Controlador</servlet-name>
        <servlet-class>Controlador.Controlador</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ControladorIMG</servlet-name>
        <servlet-class>Controlador.ControladorIMG</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ControladorLogin</servlet-name>
        <servlet-class>Controlador.ControladorLogin</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ControladorJuego</servlet-name>
        <servlet-class>Controlador.ControladorJuego</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ControladorDetalleJuegos</servlet-name>
        <servlet-class>Controlador.ControladorDetalleJuegos</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ControladorDataTable</servlet-name>
        <servlet-class>Controlador.ControladorDataTable</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>srvReclamaciones</servlet-name>
        <servlet-class>Controlador.srvReclamaciones</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Controlador</servlet-name>
        <url-pattern>/Controlador</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ControladorIMG</servlet-name>
        <url-pattern>/ControladorIMG</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ControladorLogin</servlet-name>
        <url-pattern>/ControladorLogin</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ControladorJuego</servlet-name>
        <url-pattern>/ControladorJuego</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ControladorDetalleJuegos</servlet-name>
        <url-pattern>/ControladorDetalleJuegos</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ControladorDataTable</servlet-name>
        <url-pattern>/ControladorDataTable</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>srvReclamaciones</servlet-name>
        <url-pattern>/srvReclamaciones</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
